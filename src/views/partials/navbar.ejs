<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#111315]/90 backdrop-blur-md">

    <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 lg:px-8">

        <!-- Brand -->
        <a href="/" class="text-xl font-semibold tracking-[0.18em] uppercase">
            Kathakora
        </a>

        <!-- Desktop -->
        <ul class="hidden md:flex items-center gap-8 text-sm tracking-wide">
            <li><a href="/" class="hover:text-stone-300 transition">Home</a></li>
            <li><a href="/shop" class="hover:text-stone-300 transition">Shop</a></li>
            <li><a href="/#story" class="hover:text-stone-300 transition">About</a></li>
            <li><a href="/#contact" class="hover:text-stone-300 transition">Contact</a></li>

            <% if (user && user.role === "admin") { %>
                <li>
                    <a href="/admin" class="hover:text-stone-300 transition">
                        Dashboard
                    </a>
                </li>
            <% } %>
        </ul>

        <!-- Desktop Actions -->
        <div class="hidden md:flex items-center gap-4">

            <a
                href="/cart"
                class="rounded-full border border-white/20 px-4 py-2 text-sm transition hover:bg-white hover:text-black">
                Cart
            </a>

            <% if (user) { %>

                <span class="text-sm text-stone-300">
                    <%= user.name.split(" ")[0] %>
                </span>

                <a
                    href="/auth/logout"
                    class="rounded-full bg-white px-4 py-2 text-sm font-medium text-black transition hover:opacity-90">
                    Logout
                </a>

            <% } else { %>

                <a
                    href="/auth/google"
                    class="rounded-full bg-white px-4 py-2 text-sm font-medium text-black transition hover:opacity-90">
                    Login
                </a>

            <% } %>

        </div>

        <!-- Mobile Button -->
        <button
            id="menu-btn"
            class="text-2xl md:hidden"
            aria-label="Toggle menu">
            ☰
        </button>

    </nav>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="hidden border-t border-white/10 bg-[#111315]">

        <div class="flex flex-col space-y-5 px-5 py-5">

            <a href="/">Home</a>
            <a href="/shop">Shop</a>
            <a href="/#story">About</a>
            <a href="/#contact">Contact</a>

            <% if (user && user.role === "admin") { %>
                <a href="/admin">Dashboard</a>
            <% } %>

            <a
                href="/cart"
                class="rounded-md border border-white/20 py-3 text-center">
                Cart
            </a>

            <% if (user) { %>

                <span class="text-center text-stone-300">
                    <%= user.name %>
                </span>

                <a
                    href="/auth/logout"
                    class="rounded-md bg-white py-3 text-center text-black">
                    Logout
                </a>

            <% } else { %>

                <a
                    href="/auth/google"
                    class="rounded-md bg-white py-3 text-center text-black">
                    Login with Google
                </a>

            <% } %>

        </div>

    </div>

</header>

<script src="/js/navbar.js"></script>