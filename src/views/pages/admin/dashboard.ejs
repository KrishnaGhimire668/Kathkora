<%- include("../../partials/head") %>
<%- include("../../partials/navbar") %>

<main class="mx-auto max-w-7xl px-6 pt-24 pb-20">

    <div class="mb-12">

        <p class="uppercase tracking-[0.3em] text-sm text-stone-500">
            Admin
        </p>

        <h1 class="mt-3 text-5xl font-semibold">
            Dashboard
        </h1>

        <p class="mt-4 max-w-2xl text-stone-400">
            Manage your store from one place.
        </p>

    </div>

    <!-- Stats -->

    <div class="mb-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">

        <div class="rounded-3xl border border-white/10 p-8">

            <p class="text-stone-400">
                Products
            </p>

            <h2 class="mt-3 text-4xl font-semibold">
                <%= stats.products %>
            </h2>

        </div>

        <div class="rounded-3xl border border-white/10 p-8">

            <p class="text-stone-400">
                Orders
            </p>

            <h2 class="mt-3 text-4xl font-semibold">
                <%= stats.orders %>
            </h2>

        </div>

        <div class="rounded-3xl border border-white/10 p-8">

            <p class="text-stone-400">
                Users
            </p>

            <h2 class="mt-3 text-4xl font-semibold">
                <%= stats.users %>
            </h2>

        </div>

        <div class="rounded-3xl border border-white/10 p-8">

            <p class="text-stone-400">
                Revenue
            </p>

            <h2 class="mt-3 text-4xl font-semibold">
                Rs. <%= stats.revenue.toLocaleString() %>
            </h2>

        </div>

    </div>

    <!-- Quick Actions -->

    <div class="grid gap-6 md:grid-cols-2">

        <a
            href="/admin/products"
            class="rounded-3xl border border-white/10 p-8 transition hover:border-white hover:bg-white hover:text-black">

            <h2 class="text-2xl font-semibold">
                📦 Manage Products
            </h2>

            <p class="mt-3 opacity-80">
                Add, edit and delete products.
            </p>

        </a>

        <a
            href="/admin/orders"
            class="rounded-3xl border border-white/10 p-8 transition hover:border-white hover:bg-white hover:text-black">

            <h2 class="text-2xl font-semibold">
                📋 Manage Orders
            </h2>

            <p class="mt-3 opacity-80">
                View customer orders and update their status.
            </p>

        </a>

    </div>

</main>

<%- include("../../partials/footer") %>