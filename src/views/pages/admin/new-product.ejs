<%- include("../../partials/head") %>
<%- include("../../partials/navbar") %>

<main class="mx-auto max-w-3xl px-6 py-24">

    <h1 class="mb-10 text-4xl font-semibold">
        Add Product
    </h1>

    <form action="/admin/products" method="POST" class="space-y-6">

        <input
            type="text"
            name="name"
            placeholder="Product Name"
            required
            class="w-full rounded-xl border border-white/10 bg-transparent p-4">

        <input
            type="text"
            name="slug"
            placeholder="Slug"
            required
            class="w-full rounded-xl border border-white/10 bg-transparent p-4">

        <input
            type="number"
            name="price"
            placeholder="Price"
            required
            class="w-full rounded-xl border border-white/10 bg-transparent p-4">

        <input
            type="text"
            name="image"
            placeholder="/images/products/shirt.jpg"
            required
            class="w-full rounded-xl border border-white/10 bg-transparent p-4">

        <input
            type="text"
            name="category"
            placeholder="Category"
            required
            class="w-full rounded-xl border border-white/10 bg-transparent p-4">

        <input
            type="number"
            name="stock"
            placeholder="Stock"
            required
            class="w-full rounded-xl border border-white/10 bg-transparent p-4">

        <input
            type="text"
            name="sizes"
            value="S,M,L,XL"
            class="w-full rounded-xl border border-white/10 bg-transparent p-4">

        <label class="flex items-center gap-3">
            <input type="checkbox" name="featured">
            Featured Product
        </label>

        <button
            class="rounded-full bg-white px-8 py-4 font-semibold text-black">

            Save Product

        </button>

    </form>

</main>

<%- include("../../partials/footer") %>