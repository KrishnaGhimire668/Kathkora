<%- include("../../partials/head") %>
<%- include("../../partials/navbar") %>

<main class="mx-auto max-w-3xl px-6 py-24">

  <h1 class="mb-10 text-4xl font-semibold">
    Add Product
  </h1>

  <form action="/admin/products" method="POST" enctype="multipart/form-data" class="space-y-6">

    <div>
      <label class="mb-2 block text-sm text-stone-400">
        Product Name
      </label>

      <input type="text" name="name" required class="w-full rounded-xl border border-white/10 bg-transparent p-4">
    </div>

    <div>
      <label class="mb-2 block text-sm text-stone-400">
        Slug
      </label>

      <input type="text" name="slug" required class="w-full rounded-xl border border-white/10 bg-transparent p-4">
    </div>

    <div class="grid gap-6 md:grid-cols-2">

      <div>
        <label class="mb-2 block text-sm text-stone-400">
          Price (Rs.)
        </label>

        <input type="number" name="price" required class="w-full rounded-xl border border-white/10 bg-transparent p-4">
      </div>

      <div>
        <label class="mb-2 block text-sm text-stone-400">
          Stock
        </label>

        <input type="number" name="stock" required class="w-full rounded-xl border border-white/10 bg-transparent p-4">
      </div>

    </div>

    <div>
      <label class="mb-2 block text-sm text-stone-400">
        Product Image
      </label>

      <input type="file" name="image" accept="image/*" required class="block w-full rounded-xl border border-white/10 p-4 file:mr-4 file:rounded-lg file:border-0 file:bg-white file:px-4 file:py-2 file:text-black">
    </div>

    <div>
      <label class="mb-2 block text-sm text-stone-400">
        Category
      </label>

      <select name="category" class="w-full rounded-xl border border-white/10 bg-[#111315] p-4">

        <option>T-Shirts</option>
        <option>Hoodies</option>
        <option>Jackets</option>
        <option>Accessories</option>

      </select>
    </div>

    <div>
      <label class="mb-2 block text-sm text-stone-400">
        Sizes
      </label>

      <input type="text" name="sizes" value="S,M,L,XL" class="w-full rounded-xl border border-white/10 bg-transparent p-4">
    </div>

    <label class="flex items-center gap-3">

      <input type="checkbox" name="featured">

      Featured Product

    </label>

    <button class="rounded-full bg-white px-8 py-4 font-semibold text-black">

      Save Product

    </button>

  </form>

</main>

<%- include("../../partials/footer") %>