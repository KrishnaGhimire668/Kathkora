<%- include("../partials/head") %>

<%- include("../partials/navbar") %>

<main class="pt-20">

<section class="mx-auto grid max-w-7xl gap-16 px-6 py-16 lg:grid-cols-2">

    <div>

        <div class="aspect-[4/5] rounded-3xl bg-neutral-800">

            <img
                src="<%= product.image %>"
                alt="<%= product.name %>"
                class="h-full w-full rounded-3xl object-cover">

        </div>

    </div>

    <div>

        <p class="uppercase tracking-[0.35em] text-sm text-stone-500">
            <%= product.category %>
        </p>

        <h1 class="mt-3 text-5xl font-semibold">
            <%= product.name %>
        </h1>

        <p class="mt-6 text-3xl">
            Rs. <%= product.price.toLocaleString() %>
        </p>

        <p class="mt-10 leading-8 text-stone-400">

            Premium clothing inspired by Himalayan minimalism.
            Crafted for everyday luxury.

        </p>

        <button
            class="mt-12 rounded-full bg-white px-10 py-4 font-medium text-black">

            Add to Cart

        </button>

    </div>

</section>

</main>

<%- include("../partials/footer") %>