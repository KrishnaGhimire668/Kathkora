<%- include("../partials/head") %>

<%- include("../partials/navbar") %>

<main class="pt-20">

<section class="mx-auto grid max-w-7xl gap-16 px-6 py-16 lg:grid-cols-2">

    <!-- Product Image -->
    <div>

        <div class="aspect-[4/5] overflow-hidden rounded-3xl bg-neutral-800">

            <img
                src="<%= product.image %>"
                alt="<%= product.name %>"
                class="h-full w-full object-cover">

        </div>

    </div>

    <!-- Product Info -->
    <div>

        <p class="uppercase tracking-[0.35em] text-sm text-stone-500">
            <%= product.category %>
        </p>

        <h1 class="mt-3 text-5xl font-semibold">
            <%= product.name %>
        </h1>

        <p class="mt-6 text-3xl font-medium">
            Rs. <%= product.price.toLocaleString() %>
        </p>

        <p class="mt-8 leading-8 text-stone-400">
            Premium clothing inspired by Himalayan minimalism.
            Crafted in Nepal using timeless design and quality materials.
        </p>

        <!-- Sizes -->
        <div class="mt-10">

            <p class="mb-4 text-sm uppercase tracking-[0.3em] text-stone-500">
                Select Size
            </p>

            <div class="flex flex-wrap gap-3">

                <% product.sizes.forEach(size => { %>

                    <button
                        type="button"
                        class="rounded-full border border-white/20 px-5 py-2 transition hover:bg-white hover:text-black">

                        <%= size %>

                    </button>

                <% }) %>

            </div>

        </div>

        <!-- Add To Cart -->

        <button
            class="mt-12 rounded-full bg-white px-10 py-4 font-medium text-black transition hover:opacity-90">

            Add To Cart

        </button>

    </div>

</section>

</main>

<%- include("../partials/footer") %>