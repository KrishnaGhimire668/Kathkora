<%- include("../partials/head") %>
<%- include("../partials/navbar") %>

<main class="mx-auto max-w-7xl px-6 pt-24 pb-20">

    <div class="mb-12">

        <h1 class="text-4xl font-semibold">
            Checkout
        </h1>

        <p class="mt-3 text-stone-400">
            Complete your order.
        </p>

    </div>

    <div class="grid gap-10 lg:grid-cols-3">

        <!-- Checkout Form -->

        <form
            action="/checkout"
            method="POST"
            class="space-y-6 lg:col-span-2">

            <div>

                <label class="mb-2 block text-sm text-stone-400">
                    Full Name
                </label>

                <input
                    type="text"
                    name="name"
                    required
                    class="w-full rounded-2xl border border-white/10 bg-transparent p-4 outline-none">

            </div>

            <div>

                <label class="mb-2 block text-sm text-stone-400">
                    Email
                </label>

                <input
                    type="email"
                    name="email"
                    required
                    class="w-full rounded-2xl border border-white/10 bg-transparent p-4 outline-none">

            </div>

            <div>

                <label class="mb-2 block text-sm text-stone-400">
                    Phone
                </label>

                <input
                    type="text"
                    name="phone"
                    required
                    class="w-full rounded-2xl border border-white/10 bg-transparent p-4 outline-none">

            </div>

            <div>

                <label class="mb-2 block text-sm text-stone-400">
                    Address
                </label>

                <textarea
                    name="address"
                    rows="1"
                    required
                    class="w-full rounded-2xl border border-white/10 bg-transparent p-4 outline-none"></textarea>

            </div>

            <button
                class="rounded-full bg-white px-8 py-4 font-semibold text-black transition hover:opacity-90">

                Place Order

            </button>

        </form>

        <!-- Order Summary -->

        <div>

            <div class="sticky top-28 rounded-3xl border border-white/10 p-8">

                <h2 class="text-2xl font-semibold">
                    Order Summary
                </h2>

                <div class="mt-8 space-y-6">

                    <% items.forEach(item => { %>

                        <div class="flex items-center gap-4">

                            <img
                                src="<%= item.image %>"
                                alt="<%= item.name %>"
                                class="h-16 w-14 rounded-xl object-cover">

                            <div class="flex-1">

                                <p class="font-medium">
                                    <%= item.name %>
                                </p>

                                <p class="text-sm text-stone-400">
                                    <%= item.size %> × <%= item.quantity %>
                                </p>

                            </div>

                            <p class="font-medium">
                                Rs. <%= (item.price * item.quantity).toLocaleString() %>
                            </p>

                        </div>

                    <% }) %>

                </div>

                <hr class="my-8 border-white/10">

                <div class="flex justify-between">

                    <span class="text-stone-400">
                        Shipping
                    </span>

                    <span>
                        Free
                    </span>

                </div>

                <div class="mt-4 flex justify-between text-2xl font-semibold">

                    <span>Total</span>

                    <span>
                        Rs. <%= total.toLocaleString() %>
                    </span>

                </div>

            </div>

        </div>

    </div>

</main>

<%- include("../partials/footer") %>